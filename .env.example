# LLM 配置
LLM_PROVIDER=mock
# 支持: mock | openai | deepseek | zhipu
# mock 模式无需 API Key，使用内置模板生成逼真数据

OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# 数据库
# 相对路径会自动解析到 backend/ 目录，因此默认实际文件是 backend/recruit.db
DATABASE_URL=sqlite:///./recruit.db

# 服务器
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# 文件上传
# 相对路径会自动解析到 backend/ 目录，因此默认实际目录是 backend/uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10
