# LLM 配置
LLM_PROVIDER=mock
# 支持: mock | openai | deepseek | zhipu
# mock 模式无需 API Key，使用内置模板生成逼真数据

OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# 数据库
# 相对路径会自动解析到 backend/ 目录，因此默认实际文件是 backend/recruit.db
DATABASE_URL=sqlite:///./recruit.db

# 服务器
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
# 云平台通常会自动注入 PORT；本地不需要配置
# PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
# 线上前端地址，可填写 Vercel 域名，例如 https://your-app.vercel.app
FRONTEND_ORIGIN=

# 前端构建时使用。部署到 Vercel 时在 Vercel 环境变量中配置，不一定读取此文件。
# 示例：https://your-backend.onrender.com
VITE_API_BASE_URL=

# 文件上传
# 相对路径会自动解析到 backend/ 目录，因此默认实际目录是 backend/uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10
